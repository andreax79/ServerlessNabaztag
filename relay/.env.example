HOST=0.0.0.0
PORT=8787

# Keep both values only on the relay host. Never copy them to the rabbit.
OPENAI_API_KEY=
TTS_SIGNING_SECRET=

OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_VOICE=marin
# Realtime-2.x supports minimal, low, medium, high, and xhigh. Low is the
# OpenAI-recommended starting point for responsive production voice agents.
OPENAI_REASONING_EFFORT=low
TIME_ZONE=Europe/Rome

# Public plain-HTTP address reachable by the rabbit, without a trailing slash.
PUBLIC_BASE_URL=http://192.168.1.214:8787

# Optional fallback when the firmware does not send X-Tools-Url.
TOOLS_URL=http://192.168.1.214/vl/ai_tools.json

SESSION_TTL_SECONDS=75
MAX_AUDIO_BYTES=1048576
# Global cost guard in addition to the per-rabbit limits. Keep the relay on a
# trusted LAN; X-Rabbit-Id is an identifier, not an authentication credential.
MAX_TURNS_PER_MINUTE=60
MAX_SESSIONS=32
FFMPEG_PATH=ffmpeg
